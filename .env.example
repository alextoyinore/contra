# Supabase Configuration
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudinary Configuration
# Get these from: https://cloudinary.com/console → Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Twitter Developer App credentials
# Get these from: https://developer.x.com/ → Projects & Apps → App Settings → OAuth 2.0 Settings
VITE_TWITTER_CLIENT_ID=your_twitter_client_id
VITE_TWITTER_REDIRECT_URI=https://your-project-id.supabase.co/functions/v1/twitter-oauth
